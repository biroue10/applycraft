# No catch-all SPA fallback; unknown URLs fall through to /404.html (no soft-404s).
#
# Trailing-slash handling for the prerendered flat-`<route>.html` builds
# (/resume-builder/, /resume/templates/, /cover-letter/templates/, /job-tracker/,
# /master-profile/, /email-signature/, /personal-website/, /r/) is done in
# worker.js (TRAILING_SLASH_HTML_ASSETS): the canonical slash URL is served 200
# and the no-slash form 301s to it. Do NOT re-add `<route> <route>/ 301` rules
# here — combined with Workers Assets html_handling they create a redirect loop.
/app/ats-checker /ats-checker/ 301
/app/ats-checker/ /ats-checker/ 301
/cover-letter/builder /cover-letter-builder/ 301
/cover-letter/builder/ /cover-letter-builder/ 301
/linux-administrator-resume /examples/linux-administrator-resume/ 301
/linux-administrator-resume/ /examples/linux-administrator-resume/ 301
