# ── Core (existing) ─────────────────────────────────────────────
ANTHROPIC_API_KEY=
ALLOWED_ORIGINS=https://applycraft.io
ENVIRONMENT=production
ENABLE_DEV_ORIGINS=false

# ── Client feature flags (VITE_*, inlined at build time) ─────────
# Everything below defaults to OFF. The free, no-account builder +
# all templates + PDF/DOCX export work with NONE of these set.

# Developer-only translation bypass. Leave blank for normal builds.
# Set to the SHA-256 hex digest of your private bypass token, never the token.
VITE_DEV_BYPASS=

# Optional email capture / Master Profile cloud sync UI
VITE_ACCOUNTS_ENABLED=false
# Paid "Active Search Pass" upsell + checkout UI
VITE_PAYMENTS_ENABLED=false

# Privacy-respecting analytics (Plausible, cookieless)
VITE_ANALYTICS_ENABLED=false
# Paste the EXACT script src from the Plausible dashboard snippet. The modern
# tagged script encodes your site in the URL (e.g. .../js/pa-XXXX.js) and needs
# no domain. For the classic script (.../js/script.js) also set the domain below.
VITE_PLAUSIBLE_SRC=https://plausible.io/js/pa-XXXXXXXXXXXX.js
# Only needed for the classic script.js (leave blank for the tagged pa-*.js).
VITE_PLAUSIBLE_DOMAIN=

# Active Search Pass pricing (one-time, NOT recurring)
VITE_PASS_PRICE_USD=7
VITE_PASS_DAYS=7
# Lemon Squeezy variant id for the pass (client only needs the id)
VITE_LEMONSQUEEZY_VARIANT_ID=

# ── Server secrets (Cloudflare Pages env vars / Functions) ───────
# Lemon Squeezy (merchant of record) — checkout + webhook
LEMONSQUEEZY_API_KEY=
LEMONSQUEEZY_STORE_ID=
LEMONSQUEEZY_VARIANT_ID=
LEMONSQUEEZY_WEBHOOK_SECRET=

# Developer-only translation API rate-limit bypass. Never commit a real value.
DEV_BYPASS_TOKEN=

# Magic-link email delivery (Resend). Without it, auth returns a
# dev link in non-production and is a no-op stub in production.
RESEND_API_KEY=
MAIL_FROM=ApplyCraft <login@applycraft.io>

# Canonical origin used to build links/redirects (falls back to request origin)
APP_ORIGIN=https://applycraft.io

# Pass duration override (days). Defaults to 7 if unset.
PASS_DAYS=7

# KV namespace binding required (wrangler.toml / dashboard): AC_KV
